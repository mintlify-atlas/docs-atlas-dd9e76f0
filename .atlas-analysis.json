  "keyFeatures": [
    "Multi-system chiptune tracker with 200+ sound chip presets",
    "Pattern-based music composition with up to 32 chips or 128 channels",
    "DefleMask compatibility (.dmf, .dmp, .dmw formats)",
    "Built-in instrument, wavetable, and sample editors",
    "Multiple export formats (VGM, ZSM, TIunA, SAP, audio files)",
    "Quality emulation cores (Nuked, MAME, SameBoy, Mednafen)",
    "MIDI input support and modular interface",
    "Advanced features: FM macros, wavetable synthesizer, per-channel oscilloscope"
  ],
  "publicApiSurface": [
    "GUI Application (furnace.exe / furnace binary)",
    "Console mode playback: furnace -console <file>",
    "Command line options: -view, -audio, -output",
    "File formats: .fur (native), .dmf (DefleMask), .dmp (instruments), .dmw (wavetables)",
    "Export formats: .vgm, .zsm, .wav, .mp3, .flac, .ogg",
    "CMake build system with multiple configuration options",
    "Plugin/preset system for chip configurations"
  ]
